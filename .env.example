# --- Database ---
# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aaastreamer

# --- JWT auth ---
# Generate a strong secret, e.g.  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Embeddings ---
EMBEDDING_DIM=390

# --- TMDB ---
# v3 API key from https://www.themoviedb.org/settings/api
# Used to lazily fetch & cache person biographies and movie collections.
TMDB_API_KEY=

# --- App ---
PROJECT_NAME=aaastreamer API
# Comma-separated list of allowed CORS origins (use * for all)
CORS_ORIGINS=*
